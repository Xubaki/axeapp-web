# ============================================================
# AxéApp Web — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# URL da API do app mobile (obrigatório)
# Exemplo: https://api.appaxe.com.br
NEXT_PUBLIC_API_URL=https://api.appaxe.com.br

# Segredo JWT para validar tokens de sessão (obrigatório)
# Deve ser o MESMO valor usado no app mobile (server/.env)
# Gere com: openssl rand -base64 32
JWT_SECRET=seu-segredo-jwt-aqui

# Ambiente (development | production)
NODE_ENV=production

# ============================================================
# SMTP para e-mails de recuperação de senha (opcional em dev)
# Usado pelo app mobile — o site apenas chama a API
# Configure no app mobile (axe_app/.env):
#   SMTP_URL=smtp://user:pass@smtp.brevo.com:587
#   MAIL_FROM=noreply@appaxe.com.br
# ============================================================
